    { "id": 29, "arabic": "الْمُدَّثِّرُ", "transliteration": "Al-Muddaththir", "translation": "The Cloaked One", "meaning": "The one covered with a cloak, mentioned in the Quran" },
    { "id": 30, "arabic": "عَبْدُ اللهِ", "transliteration": "Abdullah", "translation": "The Servant of Allah", "meaning": "The devoted slave and worshipper of Allah" },
    { "id": 31, "arabic": "خَلِيلُ اللهِ", "transliteration": "Khalilullah", "translation": "The Close Friend of Allah", "meaning": "The beloved and intimate friend of Allah" },
    { "id": 32, "arabic": "صَفِيُّ اللهِ", "transliteration": "Safiyyullah", "translation": "The Chosen of Allah", "meaning": "The one chosen and selected by Allah" },
    { "id": 33, "arabic": "حَبِيبُ اللهِ", "transliteration": "Habibullah", "translation": "The Beloved of Allah", "meaning": "The most beloved to Allah among all creation" },
    { "id": 34, "arabic": "نَجِيُّ اللهِ", "transliteration": "Najiyyullah", "translation": "The Confidant of Allah", "meaning": "The one entrusted with divine secrets" },
    { "id": 35, "arabic": "الْمُخْتَارُ", "transliteration": "Al-Mukhtar", "translation": "The Chosen One", "meaning": "The one selected above all by Allah" },
    { "id": 36, "arabic": "الْمُصْطَفَى", "transliteration": "Al-Mustafa", "translation": "The Purified Chosen One", "meaning": "The one purified and selected by Allah" },
    { "id": 37, "arabic": "الْمُجْتَبَى", "transliteration": "Al-Mujtaba", "translation": "The Elected One", "meaning": "The one elected by Allah for prophethood" },
    { "id": 38, "arabic": "الطَّيِّبُ", "transliteration": "At-Tayyib", "translation": "The Pure", "meaning": "The one pure in character, lineage, and spirit" },
    { "id": 39, "arabic": "الطَّاهِرُ", "transliteration": "At-Tahir", "translation": "The Purified", "meaning": "The one purified in body and soul" },
    { "id": 40, "arabic": "الزَّكِيُّ", "transliteration": "Az-Zakiyy", "translation": "The Righteous", "meaning": "The one of spotless purity and integrity" },
    { "id": 41, "arabic": "الْمُتَوَكِّلُ", "transliteration": "Al-Mutawakkil", "translation": "The One Who Trusts in Allah", "meaning": "The one who fully relies on and surrenders to Allah" },
    { "id": 42, "arabic": "الْهَادِي", "transliteration": "Al-Hadi", "translation": "The Guide", "meaning": "The one who guides to the straight path" },
    { "id": 43, "arabic": "الْمَهْدِيُّ", "transliteration": "Al-Mahdi", "translation": "The Rightly Guided", "meaning": "The one guided by Allah in all affairs" },
    { "id": 44, "arabic": "الشَّاهِدُ", "transliteration": "Ash-Shahid", "translation": "The Witness", "meaning": "The one present as a witness for his Ummah" },
    { "id": 45, "arabic": "الشَّهِيرُ", "transliteration": "Ash-Shahir", "translation": "The Famous", "meaning": "The one renowned throughout all of existence" },
    { "id": 46, "arabic": "الْحَمِيدُ", "transliteration": "Al-Hamid", "translation": "The Praiseworthy", "meaning": "The one worthy of all praise" },
    { "id": 47, "arabic": "الْمَحْمُودُ", "transliteration": "Al-Mahmud", "translation": "The Glorified", "meaning": "The one whom Allah glorifies and praises" },
    { "id": 48, "arabic": "الْوَلِيُّ", "transliteration": "Al-Waliyy", "translation": "The Friend", "meaning": "The guardian and ally of the believers" },
    { "id": 49, "arabic": "الْمُبَارَكُ", "transliteration": "Al-Mubarak", "translation": "The Blessed", "meaning": "The one whose presence is a blessing" },
    { "id": 50, "arabic": "الْمُنِيرُ", "transliteration": "Al-Munir", "translation": "The Radiant", "meaning": "The one who radiates divine light and guidance" },
    { "id": 51, "arabic": "الْأَوَّلُ", "transliteration": "Al-Awwal", "translation": "The First", "meaning": "The first in creation among prophets" },
    { "id": 52, "arabic": "الْآخِرُ", "transliteration": "Al-Akhir", "translation": "The Last", "meaning": "The last of all prophets and messengers" },
    { "id": 53, "arabic": "الظَّاهِرُ", "transliteration": "Az-Zahir", "translation": "The Manifest", "meaning": "The one whose prophethood is manifest to all" },
    { "id": 54, "arabic": "الْبَاطِنُ", "transliteration": "Al-Batin", "translation": "The Inner", "meaning": "The one with deep inner spiritual knowledge" },
    { "id": 55, "arabic": "الشَّرِيفُ", "transliteration": "Ash-Sharif", "translation": "The Honourable", "meaning": "The most noble in lineage and character" },
    { "id": 56, "arabic": "الْكَامِلُ", "transliteration": "Al-Kamil", "translation": "The Perfect", "meaning": "The one perfect in morals and character" },
    { "id": 57, "arabic": "الْفَاضِلُ", "transliteration": "Al-Fadil", "translation": "The Virtuous", "meaning": "The most virtuous of all human beings" },
    { "id": 58, "arabic": "الْقَاسِمُ", "transliteration": "Al-Qasim", "translation": "The Distributor", "meaning": "The one who distributes and divides what Allah gives" },
    { "id": 59, "arabic": "الْعَالِمُ", "transliteration": "Al-Alim", "translation": "The Knowledgeable", "meaning": "The one blessed with divine knowledge" },
    { "id": 60, "arabic": "الصَّابِرُ", "transliteration": "As-Sabir", "translation": "The Patient", "meaning": "The one most patient in hardship and trial" },
    { "id": 61, "arabic": "الشَّاكِرُ", "transliteration": "Ash-Shakir", "translation": "The Grateful", "meaning": "The one most grateful to Allah" },
    { "id": 62, "arabic": "الْمُؤَيَّدُ", "transliteration": "Al-Mu'ayyad", "translation": "The Supported", "meaning": "The one divinely aided and supported by Allah" },
    { "id": 63, "arabic": "الرَّفِيعُ", "transliteration": "Ar-Rafi", "translation": "The Elevated", "meaning": "The one whose rank has been raised by Allah" },
    { "id": 64, "arabic": "الشَّفِيعُ", "transliteration": "Ash-Shafi", "translation": "The Intercessor", "meaning": "The intercessor for believers on the Day of Judgment" },
    { "id": 65, "arabic": "الْمَأْمُونُ", "transliteration": "Al-Ma'mun", "translation": "The Trusted", "meaning": "The one trusted and relied upon by all" },
    { "id": 66, "arabic": "الْغَيْثُ", "transliteration": "Al-Ghayth", "translation": "The Rain", "meaning": "The one whose coming was like life-giving rain" },
    { "id": 67, "arabic": "الرَّحْمَةُ", "transliteration": "Ar-Rahmah", "translation": "The Mercy", "meaning": "The embodiment of mercy for all worlds" },
    { "id": 68, "arabic": "الْمُنْذِرُ", "transliteration": "Al-Mundhir", "translation": "The Admonisher", "meaning": "The one who admonishes against evil and error" },
    { "id": 69, "arabic": "خَيْرُ الْبَرِيَّةِ", "transliteration": "Khayrul Bariyyah", "translation": "The Best of Creation", "meaning": "The finest of all created beings" },
    { "id": 70, "arabic": "سَيِّدُ الْأَنْبِيَاءِ", "transliteration": "Sayyidul Anbiya", "translation": "The Master of Prophets", "meaning": "The chief and leader of all prophets" },
    { "id": 71, "arabic": "إِمَامُ الْأَتْقِيَاءِ", "transliteration": "Imamul Atqiya", "translation": "The Imam of the Pious", "meaning": "The leader of all God-fearing people" },
    { "id": 72, "arabic": "سَيِّدُ الْمُرْسَلِينَ", "transliteration": "Sayyidul Mursalin", "translation": "The Master of Messengers", "meaning": "The foremost of all messengers sent by Allah" },
    { "id": 73, "arabic": "خَاتَمُ النَّبِيِّينَ", "transliteration": "Khatamun Nabiyyeen", "translation": "The Seal of Prophets", "meaning": "The last and final prophet, closing all prophethood" },
    { "id": 74, "arabic": "قَائِدُ الْغُرِّ الْمُحَجَّلِينَ", "transliteration": "Qa'idul Ghurril Muhajjalin", "translation": "The Leader of the Bright-Faced Ones", "meaning": "Leader of those whose faces glow with prayer on Judgment Day" },
    { "id": 75, "arabic": "صَاحِبُ الشَّفَاعَةِ", "transliteration": "Sahibush Shafa'ah", "translation": "The Possessor of Intercession", "meaning": "The one granted the great intercession by Allah" },
    { "id": 76, "arabic": "صَاحِبُ الْمَقَامِ الْمَحْمُودِ", "transliteration": "Sahibul Maqamil Mahmud", "translation": "The Possessor of the Praised Station", "meaning": "The one who holds the highest station on Judgment Day" },
    { "id": 77, "arabic": "صَاحِبُ الْحَوْضِ", "transliteration": "Sahibul Hawd", "translation": "The Owner of the Fountain", "meaning": "The one granted the Kawthar fountain on Judgment Day" },
    { "id": 78, "arabic": "صَاحِبُ اللِّوَاءِ", "transliteration": "Sahibul Liwa'", "translation": "The Bearer of the Banner", "meaning": "The one who carries the banner of praise on Judgment Day" },
    { "id": 79, "arabic": "الْبُرْهَانُ", "transliteration": "Al-Burhan", "translation": "The Proof", "meaning": "The manifest proof of Allah's existence and mercy" },
    { "id": 80, "arabic": "الرُّوحُ الْأَمِينُ", "transliteration": "Ar-Ruh ul-Amin", "translation": "The Trustworthy Spirit", "meaning": "The trusted one in spirit and divine message" },
    { "id": 81, "arabic": "الْمُطَهَّرُ", "transliteration": "Al-Mutahhar", "translation": "The Purified One", "meaning": "The one purified by Allah from all sin" },
    { "id": 82, "arabic": "الْكَلِيمُ", "transliteration": "Al-Kalim", "translation": "The One Who Spoke", "meaning": "The one who was spoken to by Allah" },
    { "id": 83, "arabic": "الصِّرَاطُ الْمُسْتَقِيمُ", "transliteration": "As-Siratul Mustaqim", "translation": "The Straight Path", "meaning": "The embodiment of the straight and righteous path" },
    { "id": 84, "arabic": "نِعْمَةُ اللهِ", "transliteration": "Ni'matullah", "translation": "The Grace of Allah", "meaning": "The greatest favor and blessing of Allah upon creation" },
    { "id": 85, "arabic": "الرَّحْمَةُ الْمُهْدَاةُ", "transliteration": "Ar-Rahmatul Muhdah", "translation": "The Gifted Mercy", "meaning": "The mercy gifted by Allah to all the worlds" },
    { "id": 86, "arabic": "الصَّفِيُّ", "transliteration": "As-Safiyy", "translation": "The Sincere Friend", "meaning": "The purest and most chosen companion of Allah" },
    { "id": 87, "arabic": "الْمُكَرَّمُ", "transliteration": "Al-Mukarram", "translation": "The Honored", "meaning": "The one honored above all by Allah" },
    { "id": 88, "arabic": "الشَّيِّدُ", "transliteration": "Ash-Shayyid", "translation": "The Exalted in Rank", "meaning": "The one raised high in rank and dignity" },
    { "id": 89, "arabic": "النَّاصِرُ", "transliteration": "An-Nasir", "translation": "The Helper", "meaning": "The one who aids and supports the truth" },
    { "id": 90, "arabic": "الْمَنْصُورُ", "transliteration": "Al-Mansur", "translation": "The Victorious", "meaning": "The one granted victory by Allah" },
    { "id": 91, "arabic": "الصَّادِعُ بِالْحَقِّ", "transliteration": "As-Sadi' bil-Haqq", "translation": "The Proclaimer of Truth", "meaning": "The one who proclaims the truth without fear" },
    { "id": 92, "arabic": "أَبُو الْقَاسِمِ", "transliteration": "Abu'l Qasim", "translation": "Father of Qasim", "meaning": "His kunya, the father of his son Qasim" },
    { "id": 93, "arabic": "أَبُو إِبْرَاهِيمَ", "transliteration": "Abu Ibrahim", "translation": "Father of Ibrahim", "meaning": "Father of his son Ibrahim, who passed in infancy" },
    { "id": 94, "arabic": "ابْنُ عَبْدِ اللهِ", "transliteration": "Ibn Abdillah", "translation": "Son of Abdullah", "meaning": "The son of Abdullah, his noble father" },
    { "id": 95, "arabic": "الْمُتَهَجِّدُ", "transliteration": "Al-Mutahajjid", "translation": "The Night Worshipper", "meaning": "The one devoted to night prayers and worship" },
    { "id": 96, "arabic": "الزَّاهِدُ", "transliteration": "Az-Zahid", "translation": "The Ascetic", "meaning": "The one detached from worldly pleasures" },
    { "id": 97, "arabic": "الْعَابِدُ", "transliteration": "Al-Abid", "translation": "The Devoted Worshipper", "meaning": "The one most devoted in worship to Allah" },
    { "id": 98, "arabic": "الْمُجَاهِدُ", "transliteration": "Al-Mujahid", "translation": "The One Who Strives", "meaning": "The one who strives in the path of Allah" },
    { "id": 99, "arabic": "خَيْرُ الْخَلْقِ", "transliteration": "Khayrul Khalq", "translation": "The Best of All Creation", "meaning": "The finest and most perfect of all Allah's creation" }
  ],

  "famousDuas": [
    {
      "id": "1",
      "category": "Daily Essentials",
      "title": "Bismillah — Starting Anything",
      "arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
      "translation": "In the name of Allah, the Most Gracious, the Most Merciful."
    },
    {
      "id": "2",
      "category": "Daily Essentials",
      "title": "Rabbana Atina",
      "arabic": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ",
      "translation": "Our Lord, grant us good in this world and good in the Hereafter and protect us from the punishment of the Fire."
    },
    {
      "id": "3",
      "category": "Knowledge",
      "title": "Dua for Knowledge",
      "arabic": "رَّبِّ زِدْنِي عِلْمًا",
      "translation": "My Lord, increase me in knowledge."
    },
    {
      "id": "4",
      "category": "Forgiveness",
      "title": "Dua-e-Yunus",
      "arabic": "لَا إِلَٰهَ إِلَّا أَنتَ سُبْحَانَكَ إِنِّي كُنتُ مِنَ الظَّالِمِينَ",
      "translation": "There is no deity except You. Glory be to You. Indeed, I have been among the wrongdoers."
    },
    {
      "id": "5",
      "category": "Protection",
      "title": "Hasbunallahu Wa Ni'mal Wakeel",
      "arabic": "حَسْبُنَا اللَّهُ وَنِعْمَ الْوَكِيلُ",
      "translation": "Allah is sufficient for us, and He is the best Disposer of affairs."
    },
    {
      "id": "6",
      "category": "Protection",
      "title": "Morning & Evening Protection",
      "arabic": "بِسْمِ اللَّهِ الَّذِي لَا يَضُرُّ مَعَ اسْمِهِ شَيْءٌ فِي الْأَرْضِ وَلَا فِي السَّمَاءِ وَهُوَ السَّمِيعُ الْعَلِيمُ",
      "translation": "In the name of Allah, with whose name nothing on earth or in heaven can cause harm, and He is the All-Hearing, the All-Knowing."
    },
    {
      "id": "7",
      "category": "Forgiveness",
      "title": "Sayyidul Istighfar",
      "arabic": "اللَّهُمَّ أَنْتَ رَبِّي لَا إِلَٰهَ إِلَّا أَنْتَ خَلَقْتَنِي وَأَنَا عَبْدُكَ",
      "translation": "O Allah, You are my Lord. There is no deity except You. You created me and I am Your servant."
    },
    {
      "id": "8",
      "category": "Family",
      "title": "Dua for Parents",
      "arabic": "رَّبِّ ارْحَمْهُمَا كَمَا رَبَّيَانِي صَغِيرًا",
      "translation": "My Lord, have mercy upon them as they brought me up when I was small."
    },
    {
      "id": "9",
      "category": "Family",
      "title": "Dua for Spouse & Children",
      "arabic": "رَبَّنَا هَبْ لَنَا مِنْ أَزْوَاجِنَا وَذُرِّيَّاتِنَا قُرَّةَ أَعْيُنٍ وَاجْعَلْنَا لِلْمُتَّقِينَ إِمَامًا",
      "translation": "Our Lord, grant us comfort in our spouses and offspring and make us leaders for the righteous."
    },
    {
      "id": "10",
      "category": "Rizq",
      "title": "Dua for Halal Rizq",
      "arabic": "اللَّهُمَّ اكْفِنِي بِحَلَالِكَ عَنْ حَرَامِكَ وَأَغْنِنِي بِفَضْلِكَ عَمَّنْ سِوَاكَ",
      "translation": "O Allah, suffice me with what You have made lawful instead of what You have forbidden and enrich me by Your bounty from all others."
    },
    {
      "id": "11",
      "category": "Guidance",
      "title": "Dua for Guidance",
      "arabic": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْهُدَى وَالتُّقَى وَالْعَفَافَ وَالْغِنَى",
      "translation": "O Allah, I ask You for guidance, piety, chastity and self-sufficiency."
    },
    {
      "id": "12",
      "category": "Character",
      "title": "Dua for Good Character",
      "arabic": "اللَّهُمَّ كَمَا حَسَّنْتَ خَلْقِي فَحَسِّنْ خُلُقِي",
      "translation": "O Allah, just as You have made my appearance beautiful, make my character beautiful."
    },
    {
      "id": "13",
      "category": "Anxiety",
      "title": "Dua for Anxiety",
      "arabic": "اللَّهُمَّ إِنِّي عَبْدُكَ وَابْنُ عَبْدِكَ وَابْنُ أَمَتِكَ",
      "translation": "O Allah, I am Your servant, son of Your servant and son of Your maidservant."
    },
    {
      "id": "14",
      "category": "Sleep",
      "title": "Before Sleeping",
      "arabic": "اللَّهُمَّ بِاسْمِكَ أَمُوتُ وَأَحْيَا",
      "translation": "O Allah, in Your name I die and I live."
    },
    {
      "id": "15",
      "category": "Home",
      "title": "Entering Home",
      "arabic": "بِسْمِ اللَّهِ وَلَجْنَا وَبِسْمِ اللَّهِ خَرَجْنَا وَعَلَى اللَّهِ رَبِّنَا تَوَكَّلْنَا",
      "translation": "In the name of Allah we enter, in the name of Allah we leave, and upon Allah, our Lord, we rely."
    }
  ]
}